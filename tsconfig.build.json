{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "allowImportingTsExtensions": false,
    "declaration": false,
    "sourceMap": false,
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "paths": {}
  },
  "include": ["server/**/*", "shared/**/*"],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx"]
}
