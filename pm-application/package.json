{
  "name": "pm-application",
  "version": "1.0.0",
  "description": "Standalone Project Management Application with MySQL database",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "server:dev:refresh": "nodemon server/index.js --exec \"node server/index.js && node refresh-browser.js\"",
    "client:dev": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "db:migrate": "node database/migrate.js",
    "db:seed": "node database/seed.js",
    "refresh": "node refresh-browser.js"
  },
  "keywords": [
    "project-management",
    "mysql",
    "standalone",
    "api"
  ],
  "author": "Guyana Civic",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "pino": "^9.11.0",
    "pino-pretty": "^13.1.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@vitejs/plugin-react": "^5.0.3",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.6"
  }
}
